# 連到與 Express 相同的 sqlite 檔（strangler 期間共用）
# 正式環境＝Express container 掛載的 volume：/usr/src/app/db/db.sqlite
DATABASE_URL=sqlite:///usr/src/app/db/db.sqlite
DATABASE_MAX_CONNECTIONS=5

# 未接管的路由代理回 Express
EXPRESS_UPSTREAM=http://127.0.0.1:3001

# Rust 服務監聽位址（正式環境讓 nginx /api/ 指到這）
BIND_ADDR=127.0.0.1:3002

# JWT 簽章密鑰，**必須與正在跑的 Express 完全相同**（HS256）。
# ⚠️ 注意：以 Express 實際執行環境的值為準（docker exec <c> printenv JWT_SECRET），
#    不是 server/.env 檔——兩者可能漂移（.env 改了但容器沒重啟）。
JWT_SECRET=__與_Express_相同__

# 日誌等級
RUST_LOG=info,koimsurai_web_backend=debug
