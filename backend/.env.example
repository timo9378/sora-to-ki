# sqlite 檔位置（正式環境＝compose volume：/usr/src/app/db/db.sqlite）。
# 檔案不存在會自動建立，schema 由 backend/migrations/ 管理（開機自動跑）。
DATABASE_URL=sqlite:///usr/src/app/db/db.sqlite
DATABASE_MAX_CONNECTIONS=5

# Rust 服務監聽位址（正式環境讓 nginx /api/ 指到這）
BIND_ADDR=127.0.0.1:3002

# JWT 簽章密鑰（HS256）。換掉會讓既有登入 token 全數失效。
JWT_SECRET=__換成隨機長字串__

# 日誌等級
RUST_LOG=info,koimsurai_web_backend=debug
