# 後端環境變數範例
# 請複製此檔案為 .env 並填入實際的值

# 管理員帳號
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password

# JWT 密鑰（建議使用長且隨機的字串）
JWT_SECRET=your_jwt_secret_key_here

# 伺服器設定
PORT=3001
NODE_ENV=development

# 資料庫路徑（選填）
# DB_PATH=./db.sqlite

# n8n 批次匯入 API Key
N8N_SYNC_API_KEY=your_n8n_sync_api_key

# ── Newsletter (Resend) ──────────────────────────────
# 從 https://resend.com 拿 API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 寄件人。domain 必須在 Resend dashboard 已驗證 DKIM
NEWSLETTER_FROM=Koimsurai <hello@koimsurai.com>
# 收件者回信時的回信地址（可選）
NEWSLETTER_REPLY_TO=timo9378@gmail.com
# 退訂連結基底（外部可訪問的站點 URL）
PUBLIC_SITE_URL=https://koimsurai.com

# ── 動畫瘋觀看歷史 ─────────────────────────────────
# 自動同步 ani.gamer.com.tw 的觀看紀錄到 anime_history table。
# 取得方式：登入動畫瘋 → F12 Network → 任一 api.gamer.com.tw 請求 →
# Copy as cURL，把 -b '...' 那串 cookie 整段貼進來。
# 最重要的 7 個 token：BAHAID / BAHAHASHID / BAHANICK / BAHALV /
#                     BAHAFLT / BAHAENUR / BAHARUNE
# JWT 約 14 天 expire，到期會 silently fail，需要重抓更新此 env。
BAHAMUT_COOKIE=BAHAID=your_id; BAHARUNE=eyJ0eXAi...; BAHAENUR=...; BAHAHASHID=...; BAHANICK=...; BAHALV=42; BAHAFLT=...
