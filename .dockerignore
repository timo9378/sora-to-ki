# Ignore node_modules
node_modules

# Ignore build artifacts(Docker 內 build:start 自己產 dist,別把 host 的 stale dist COPY 進 builder)
dist
build

# Ignore .env files potentially containing secrets
.env*

# Ignore Dockerfile and .dockerignore itself (optional, but good practice)
Dockerfile
.dockerignore

# Ignore Git directory
.git

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore certificate files copied temporarily
privkey.pem
fullchain.pem
target
