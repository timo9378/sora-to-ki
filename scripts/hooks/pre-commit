#!/usr/bin/env bash
# 極簡 pre-commit（C4）：擋自己手滑——只跑 CI 裡最快、最常爆的那幾項。
# 條件觸發：動到前端 ts/tsx 才跑 tsc+eslint；動到後端 rs 才跑 clippy。
# 跳過（趕時間/WIP commit）：git commit --no-verify
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# 只看「這次要 commit」的已暫存檔（ACM=新增/改/複製，不含刪除）
staged="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$staged" ] && exit 0

fail=0

if echo "$staged" | grep -qE '\.(ts|tsx)$'; then
  echo "▶ tsc --noEmit"
  pnpm exec tsc --noEmit || fail=1
  echo "▶ eslint src"
  # 與 CI 一致：只掃 src（eslint . 會掃到 build 產物噴假錯）。
  # --quiet：只擋 error，不噴 400+ 個非阻擋 warning（CI 也只看 error）。
  pnpm exec eslint src --quiet || fail=1
fi

if echo "$staged" | grep -qE '^backend/.*\.rs$'; then
  echo "▶ cargo clippy（backend）"
  ( cd backend && cargo clippy --all-targets -- -D warnings ) || fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo
  echo "✗ pre-commit 檢查沒過——修掉上面的錯再 commit。"
  echo "  （確定要先存草稿：git commit --no-verify）"
  exit 1
fi

echo "✓ pre-commit checks passed"
